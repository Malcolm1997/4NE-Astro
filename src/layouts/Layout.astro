---
import Head from "../components/Head.astro"

export interface Props {
	title: string;
	descripcion: string;
	urlCanonica?: URL;
}

const { title, descripcion, urlCanonica = Astro.url } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<Head title={title} descripcion={descripcion} urlCanonica={urlCanonica} />

	<body>
		<slot />
	</body>
</html>
